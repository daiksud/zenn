        <mxCell id="flowPanel" value="従来 — フロー情報は「変換」が必要" style="swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=64;fillColor=#fbe9e9;strokeColor=#b85450;fontSize=34;fontStyle=1;fontColor=#b85450;verticalAlign=top;arcSize=4;" vertex="1" parent="1"><mxGeometry x="70" y="145" width="1660" height="300" as="geometry" /></mxCell>
        <mxCell id="s1" value="&lt;font style=&quot;font-size:58px&quot;&gt;💬&lt;/font&gt;&lt;br&gt;Slack で議論" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=32;fontStyle=1;arcSize=12;" vertex="1" parent="flowPanel"><mxGeometry x="60" y="110" width="390" height="140" as="geometry" /></mxCell>
        <mxCell id="s2" value="&lt;font style=&quot;font-size:58px&quot;&gt;📄&lt;/font&gt;&lt;br&gt;ドキュメント化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=32;fontStyle=1;arcSize=12;" vertex="1" parent="flowPanel"><mxGeometry x="635" y="110" width="390" height="140" as="geometry" /></mxCell>
